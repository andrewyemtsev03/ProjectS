.hero-visual {
  grid-column: 2;
  grid-row: 1 / 4;
  position: relative;
  min-height: 500px;
  border-radius: 8px;
  overflow: hidden;
  background-color: #dfeaf6;
  box-shadow: 0 24px 54px rgba(0, 46, 100, 0.18);
}

.hero-carousel {
  position: relative;
  min-height: 500px;
  overflow: hidden;
}

.hero-carousel-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: scale(1.025);
  transition: opacity 0.7s ease, transform 5.5s ease;
}

.hero-carousel-slide.is-active {
  z-index: 1;
