}

.home-reveal--scale {
  transform: translate3d(0, 24px, 0) scale(0.985);
}

.home-reveal--left.is-visible,
.home-reveal--right.is-visible,
.home-reveal--scale.is-visible {
  transform: translate3d(0, 0, 0) scale(1);
}

@media (prefers-reduced-motion: reduce) {
  .home-reveal,
