  overflow: visible;
  text-align: center;
  transform: translate(var(--point-x), 0);
  animation: snupFormulaPointFloat 6s ease-in-out infinite;
}

.snup-formula-point::before {
  content: '';
  position: absolute;
  inset: 0;
  border: 1px solid rgba(21, 151, 223, 0.3);
  border-radius: inherit;
  pointer-events: none;
}

.snup-formula-point::after {
  content: '';
  position: absolute;
  top: -1px;
  left: 50%;
  width: 74px;
  height: 2px;
  border-radius: 999px;
