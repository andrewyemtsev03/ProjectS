}

.hero-metric {
  min-height: 104px;
  padding: 1rem;
  border: 1px solid rgba(0, 93, 185, 0.14);
  border-radius: 8px;
  background-color: rgba(255, 255, 255, 0.82);
  box-shadow: 0 10px 24px rgba(0, 50, 110, 0.07);
}

.hero-metric strong {
  display: block;
  color: var(--stada-blue);
  font-size: 1.55rem;
  line-height: 1.1;
  letter-spacing: 0;
}

