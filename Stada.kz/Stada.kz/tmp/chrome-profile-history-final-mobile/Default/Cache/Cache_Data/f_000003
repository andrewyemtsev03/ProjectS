  transform: scale(1);
}

.hero-carousel-slide::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(0, 93, 185, 0.46) 0%, rgba(0, 93, 185, 0.2) 30%, rgba(0, 93, 185, 0) 62%);
